# Random Password Generator (Google Colab Compatible)
import random
import string

print("===================================")
print("   Random Password Generator")
print("===================================")

while True:
    try:
        length = int(input("\nEnter password length: "))
        if length <= 0:
            print("Enter a positive number")
            continue
        break
    except:
        print("Enter a valid number")

print("\nSelect character types")

letters = input("Include Letters? (y/n): ").lower()
numbers = input("Include Numbers? (y/n): ").lower()
symbols = input("Include Symbols? (y/n): ").lower()

characters = ""

if letters == "y":
    characters += string.ascii_letters

if numbers == "y":
    characters += string.digits

if symbols == "y":
    characters += string.punctuation

if characters == "":
    print("\n❌ You must select at least one character type")
else:
    password = ''.join(random.choice(characters) for _ in range(length))

  
    print("\n✅ Generated Password:", password)

    # Strong password check
    strength = "Weak"

    if length >= 8 and numbers == "y" and symbols == "y":
        strength = "Strong"
    elif length >= 6:
        strength = "Medium"

    print("🔐 Password Strength:", strength)

print("\nThank you for using Password Generator")